{
  "name": "pi-shazam",
  "version": "0.1.2",
  "description": "Pi coding agent native codebase awareness extension - Shazam: power from multiple sources (repomap, pi-lens, serena MCP, tree-sitter, LSP) unified into one",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "pi-package",
    "pi-coding-agent",
    "extension",
    "codebase-analysis",
    "tree-sitter",
    "lsp",
    "pagerank"
  ],
  "pi": {
    "extensions": [
      "./dist"
    ]
  },
  "author": "gjczone",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gjczone/pi-shazam.git"
  },
  "dependencies": {
    "iconv-lite": "^0.6.3",
    "typebox": "^1.1.39",
    "tree-sitter": "^0.22.4",
    "tree-sitter-c": "0.23.4",
    "tree-sitter-c-sharp": "0.23.1",
    "tree-sitter-cpp": "0.23.4",
    "tree-sitter-css": "0.23.1",
    "tree-sitter-go": "0.23.4",
    "tree-sitter-html": "0.23.2",
    "tree-sitter-java": "0.23.5",
    "tree-sitter-javascript": "0.23.1",
    "tree-sitter-json": "0.24.8",
    "tree-sitter-python": "0.23.6",
    "tree-sitter-ruby": "0.23.1",
    "tree-sitter-rust": "0.23.2",
    "tree-sitter-typescript": "0.23.2",
    "vscode-jsonrpc": "^9.0.0",
    "vscode-languageserver-protocol": "^3.17.0"
  },
  "peerDependencies": {
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "tree-sitter": "^0.22.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
